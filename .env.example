# ============================================================
# Kashier Payment Gateway — single merchant account
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
#
# Find all keys in: merchant.kashier.io → Developers → API Keys
# ============================================================

KASHIER_MERCHANT_ID=MID-xxxxx-xx
KASHIER_API_KEY=your_api_key_here
KASHIER_SECRET_KEY=your_secret_key_here

# Base URLs — use the test endpoints while developing, then switch to
# production (https://api.kashier.io / https://fep.kashier.io) when going live.
KASHIER_BASE_URL=https://test-api.kashier.io
KASHIER_REFUND_BASE_URL=https://test-fep.kashier.io

KASHIER_CURRENCY=EGP

# ── Legacy (optional) ─────────────────────────────────────────
# The old two-account split is still supported as a fallback if the
# single-account keys above are not set. Leave blank unless needed.
# KASHIER_MANAGER_MERCHANT_ID=
# KASHIER_MANAGER_API_KEY=
# KASHIER_MANAGER_SECRET_KEY=
# KASHIER_STUDENT_MERCHANT_ID=
# KASHIER_STUDENT_API_KEY=
# KASHIER_STUDENT_SECRET_KEY=
