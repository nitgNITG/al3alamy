# ============================================================
# Kashier Payment Gateway — TWO separate merchant accounts
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
#
# Find all keys in: merchant.kashier.io → Developers → API Keys
# ============================================================

# ── Account 1: Manager registration-code purchases ───────────
# Money goes to the school / admin owner account
KASHIER_MANAGER_MERCHANT_ID=MID_xxxxxxxxxx
KASHIER_MANAGER_API_KEY=your_manager_api_key_here
KASHIER_MANAGER_SECRET_KEY=your_manager_secret_key_here

# ── Account 2: Student video / lesson purchases ───────────────
# Money goes to the teacher / content account
KASHIER_STUDENT_MERCHANT_ID=MID_yyyyyyyyyy
KASHIER_STUDENT_API_KEY=your_student_api_key_here
KASHIER_STUDENT_SECRET_KEY=your_student_secret_key_here

# ── Shared ────────────────────────────────────────────────────
KASHIER_CURRENCY=EGP
