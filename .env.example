# ============================================================
# Kashier Payment Gateway — TWO separate merchant accounts
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# ── Account 1: Manager registration-code purchases ───────────
# Money goes to the school / admin owner account
KASHIER_MANAGER_MERCHANT_ID=MID_xxxxxxxxxx
KASHIER_MANAGER_HASH_KEY=your_manager_hash_key_here

# ── Account 2: Student video / lesson purchases ───────────────
# Money goes to the teacher / content account
KASHIER_STUDENT_MERCHANT_ID=MID_yyyyyyyyyy
KASHIER_STUDENT_HASH_KEY=your_student_hash_key_here

# ── Shared ────────────────────────────────────────────────────
KASHIER_CURRENCY=EGP
KASHIER_CHECKOUT_URL=https://checkout.kashier.io/
