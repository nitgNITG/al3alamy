    .mform {
        display: grid;
        gap: 10px;
        grid-template-areas:
        \'username username username username\'
        \'pass pass pass pass\'
        \'email email email2 email2\'
        \'fname fname lname lname\'
        \'city city coun coun\'
        \'cat cat cat cat\'
        ;
    }

    @media screen and (max-width: 600px) {
        .mform {
            grid-template-areas:
            \'username username username username\'
            \'pass pass pass pass\'
            \'email email email email\'
            \'email2 email2 email2 email2\'
            \'fname fname fname fname\'
            \'lname lname lname lname\'
            \'city city city city\'
            \'coun coun coun coun\'
            \'cat cat cat cat\'
            ;
        }
      .my_login_form {
        padding: 98px 0px 0px 0px !important;
      }
    }

    .mform fieldset {
        border-bottom: 1px solid #dee2e600 !important;
    }
    .form-group input[type=submit] {
        padding: 15px 25px !important;
    </style>';

if ($mform_signup instanceof renderable) {
    // Try and use the renderer from the auth plugin if it exists.
    try {
        $renderer = $PAGE->get_renderer('auth_' . $authplugin->authtype);
    } catch (coding_exception $ce) {
        // Fall back on the general renderer.
        $renderer = $OUTPUT;
    }
    echo $renderer->render($mform_signup);
} else {
    // Fall back for auth plugins not using renderables.
    $mform_signup->display();
}

echo '<script>
// Get the label element by its id
var labelElement1 = document.getElementById(\'id_lastname_label\');
var labelElement2 = document.getElementById(\'id_firstname_label\');

if (labelElement1) {
  // Change the text content of the label
  labelElement1.textContent = \'العام الدراسي\';
}

if (labelElement2) {
  // Change the text content of the label
  labelElement2.textContent = \'الاسم\';
}

</script>';
echo $OUTPUT->footer();
