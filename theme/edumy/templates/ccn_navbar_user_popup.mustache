{{#notloggedin}}
  <li class="list-inline-item list_s al-auth-nav-item">
    {{! Keep legacy popup icon in case admin enables it }}
    {{#header_login_popup}}
    <a href="#" class="btn flaticon-user al-icon-only" data-toggle="modal" data-target="#exampleModalCenter">
      <span class="dn-lg">{{#str}}login_register, theme_edumy{{/str}}</span>
    </a>
    {{/header_login_popup}}

    {{! al3alamy: always-visible Login + Register pill buttons }}
    <a href="{{{ config.wwwroot }}}/login/index.php" class="al-nav-btn al-nav-login">
      <i class="fa fa-sign-in" aria-hidden="true"></i>
      <span>{{#str}}login, theme_edumy{{/str}}</span>
    </a>
    <a href="{{{ config.wwwroot }}}/login/signup.php" class="al-nav-btn al-nav-register">
      <i class="fa fa-user-plus" aria-hidden="true"></i>
      <span>{{#str}}signup, theme_edumy{{/str}}</span>
    </a>
  </li>
{{/notloggedin}}
